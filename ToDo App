JAVASCRIPT CODE:
let todo=[];
let req=prompt("Enter your request");
while(req!="quit"){
    if(req=="list"){
        console.log("---------------");
        console.log("Listing all the todo work");
        for(let i=0;i<todo.length;i++){
            console.log(todo[i]);
        }
         console.log("---------------");
    }
    else if(req=="add"){
        let add1=prompt("Enter the task to be added");
        todo.push(add1);
        console.log("Adding the element");
    }
    else if(req=="delete"){
        let delete1=prompt("enter the no. of task which you want to delete");
        delete1=parseInt(delete1);
        let delete2=todo.splice(delete1-1,1);
        console.log(delete2);
        if(delete1>todo.length){
            console.log("Entered the wrong no. of item in list");
        }
    }
    else{
        console.log("entered wrong request");
    }
    req=prompt("Enter your request");
}
console.log("You quit the App");

